{
  "manifest_version": 3,
  "name": "Matheusificador Aleatório JPG",
  "version": "2.1",
  "description": "Substitui todas as imagens da web por 24 fotos JPG aleatórias",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["*.jpeg"],
      "matches": ["<all_urls>"]
    }
  ]
}